# Anthropic API key — OPTIONAL.
# Kala runs on the Claude Agent SDK. When signed in to Claude Code (a subscription
# or OAuth session), no API key is needed. Set a real key here only to use the
# external Claude API instead of the session.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional, uncomment and set when running without the Slack CLI (npm start).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Optional, uncomment and set for OAuth mode (node app-oauth.js).
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL

# Optional, how often (ms) the deadline scheduler checks for due reminders.
# Defaults to 60000 (1 minute). Raise it for production.
# DEADLINE_CHECK_INTERVAL_MS=60000
